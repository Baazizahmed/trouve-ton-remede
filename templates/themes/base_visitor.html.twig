<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		<title>
			{% block title %}{% endblock %}
			- TrouveTonRemede
		</title>
		<meta name="description" content="{% block description %}{% endblock %}">

		<meta name="robots" content="index,follow">
		<meta
		name="author" content="TrouveTonRemede">

		{# Google Fonts #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">

		{# Favicon #}
		<link rel="icon" type="image/png" href="/favicon-96x96.png"> {% block fontAwesome %}{% endblock %}

		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}

		{% block j_Query %}{% endblock %}
		{% block specific_js %}{% endblock %}
		{% block knp_paginator_rel_links %}{% endblock %}
	</head>

	<body class="body-visitor">

		{% set pathClient = app.request.pathInfo %}

		{# NAVBAR #}
		<nav class="navbar navbar-expand-lg navbar-visitor">
			<div class="container">

				<a class="navbar-brand fw-bold" href="{{ path('app_visitor_welcome') }}">
					🌿 TrouveTonRemede
				</a>

				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>

				<div class="collapse navbar-collapse" id="navbarNav">

					<ul class="navbar-nav">

						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_visitor_welcome') ? 'active' : '' }}" href="{{ path('app_visitor_welcome') }}">
								Accueil
							</a>
						</li>

						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_visitor_product_index') ? 'active' : '' }}" href="{{ path('app_visitor_product_index') }}">
								🌿 Produits
							</a>
						</li>

						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_visitor_blog_index') ? 'active' : '' }}" href="{{ path('app_visitor_blog_index') }}">
								Blog
							</a>
						</li>

						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_visitor_contact_create') ? 'active' : '' }}" href="{{ path('app_visitor_contact_create') }}">
								Contact
							</a>
						</li>

					</ul>

					<ul
						class="navbar-nav ms-auto">

						{# PANIER #}
						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_cart_index') ? 'active' : '' }}" href="{{ path('app_cart_index') }}">
								🛒 Panier
								{% set count = cartCounter.getItemCount() %}
								{% if count > 0 %}
									<span class="badge text-bg-primary ms-1">{{ count }}</span>
								{% endif %}
							</a>
						</li>

						{% if app.user %}

							<li class="nav-item">
								<a class="nav-link {{ pathClient == path('app_order_index') ? 'active' : '' }}" href="{{ path('app_order_index') }}">
									📦 Mes commandes
								</a>
							</li>

							{% if is_granted('ROLE_ADMIN') %}
								<li class="nav-item ms-2">
									<a class="btn btn-outline-primary" href="{{ path('app_admin_home') }}">
										Admin
									</a>
								</li>
							{% endif %}

							{% if is_granted('ROLE_USER') %}
								<li class="nav-item ms-2">
									<a class="btn btn-outline-success" href="{{ path('app_user_home') }}">
										Mon compte
									</a>
								</li>
							{% endif %}

							<li class="nav-item ms-2">
								<a class="btn btn-primary" href="{{ path('app_logout') }}">
									Déconnexion
								</a>
							</li>

						{% else %}

							<li class="nav-item ms-2">
								<a class="btn btn-outline-primary" href="{{ path('app_login') }}">
									Connexion
								</a>
							</li>

							<li class="nav-item ms-2">
								<a class="btn btn-primary" href="{{ path('app_register') }}">
									Inscription
								</a>
							</li>

						{% endif %}

					</ul>

				</div>

			</div>
		</nav>

		{# MAIN #}
		<main class="main-visitor"> {% block main %}{% endblock %}
			</main>

			{# FOOTER #}
			<footer class="site-footer">
				<div class="container text-center">

					<p class="mb-2">
						🌿 TrouveTonRemede — Bien-être par les plantes
					</p>

					<div class="mb-3">
						<a href="#" class="mx-2">
							<i class="fab fa-facebook"></i>
						</a>

						<a href="#" class="mx-2">
							<i class="fab fa-instagram"></i>
						</a>

						<a href="#" class="mx-2">
							<i class="fab fa-pinterest"></i>
						</a>
					</div>

					<small class="footer-bottom">
						©
						{{ "now"|date("Y") }}
						TrouveTonRemede — Tous droits réservés
					</small>

				</div>
			</footer>

		</body>
	</html>
