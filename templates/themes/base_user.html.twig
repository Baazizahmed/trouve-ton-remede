<!DOCTYPE html>
<html lang="fr">

	<head>

		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		<title>
			{% block title %}{% endblock %}
			- Espace utilisateur | Oumi</title>
		<meta name="description" content="{% block description %}{% endblock %}">

		<meta name="robots" content="index,follow">
		<meta
		name="author" content="Oumi">

		{# Google Fonts #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

		<link
		href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

		{# Favicon #}
		<link rel="icon" type="image/png" href="/favicon-96x96.png">

		<meta
		name="theme-color" content="#2f7d32">

		{# Font Awesome #}
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer"/>

		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}

	</head>


	<body class="body-user">

		{% set pathClient = app.request.pathInfo %}


		{# NAVBAR #}
		<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">

			<div class="container">

				<a class="navbar-brand fw-bold" href="{{ path('app_visitor_welcome') }}">
					🌿 TrouveTonRemede
				</a>

				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">

					<span class="navbar-toggler-icon"></span>

				</button>


				<div class="collapse navbar-collapse" id="navbarNav">

					<ul class="navbar-nav ms-auto align-items-lg-center">

						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_user_home') ? 'active' : '' }}" href="{{ path('app_user_home') }}">
								🏠 Accueil
							</a>
						</li>


						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_user_profile_index') ? 'active' : '' }}" href="{{ path('app_user_profile_index') }}">
								👤 Mon profil
							</a>
						</li>


						<li class="nav-item">
							<a class="nav-link {{ app.request.pathInfo == path('app_cart_index') ? 'active' : '' }}" href="{{ path('app_cart_index') }}">
								🛒 Panier
								{% set count = cartCounter.getItemCount() %}
								{% if count > 0 %}
									<span class="badge text-bg-primary ms-1">{{ count }}</span>
								{% endif %}
							</a>
						</li>


						<li class="nav-item">
							<a class="nav-link {{ pathClient == path('app_order_index') ? 'active' : '' }}" href="{{ path('app_order_index') }}">
								📦 Mes commandes
							</a>
						</li>


						{% if app.user and is_granted('ROLE_ADMIN') %}
							<li class="nav-item ms-lg-2">
								<a class="btn btn-light btn-sm" href="{{ path('app_admin_home') }}">
									Admin
								</a>
							</li>
						{% endif %}


						<li class="nav-item ms-lg-2">
							<a class="btn btn-outline-light btn-sm" href="{{ path('app_visitor_welcome') }}">
								← Retour au site
							</a>
						</li>


						<li class="nav-item ms-lg-2">
							<a class="btn btn-danger btn-sm" href="{{ path('app_logout') }}">
								Déconnexion
							</a>
						</li>

					</ul>

				</div>

			</div>

		</nav>


		{# MAIN #}
		<main class="py-4"> {% block main %}{% endblock %}

			</main>


			{# FOOTER #}
			<footer class="bg-light py-3 mt-5">

				<div class="container text-center">

					<p class="mb-1">
						🌿 Espace utilisateur Oumi
					</p>

					<small class="text-muted">
						©
						{{ "now"|date("Y") }}
						— Projet DWWM
					</small>

				</div>

			</footer>


		</body>
	</html>
