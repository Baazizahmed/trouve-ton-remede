<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">

	<head>

		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">

		<title>
			{% block title %}{% endblock %}
			- Admin | Oumi</title>
		<meta name="description" content="{% block description %}{% endblock %}">
		<meta
		name="author" content="Oumi Alshifa">

		{# Favicon #}
		<link
		rel="icon" type="image/png" href="/favicon-96x96.png">

		{# Font Awesome #}
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer"/>

		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}

		<style>

			body {
				background: #f5f7fb;
			}

			.sidebar {
				min-height: 100vh;
				background: #ffffff;
				border-right: 1px solid #e5e7eb;
			}

			.sidebar .nav-link {
				color: #495057;
				font-weight: 500;
				padding: 10px 15px;
				border-radius: 6px;
				margin: 2px 10px;
			}

			.sidebar .nav-link:hover {
				background: #f1f5f9;
			}

			.sidebar .nav-link.active {
				background: #0d6efd;
				color: white;
			}

			.sidebar-title {
				font-size: 12px;
				letter-spacing: 1px;
				font-weight: 600;
				color: #6c757d;
				padding: 10px 15px;
			}

			.navbar-brand {
				font-weight: 600;
			}
		</style>

	</head>

	<body>

		{# TOP NAVBAR #}

		<header class="navbar navbar-dark bg-primary sticky-top shadow">

			<div class="container-fluid">

				<a class="navbar-brand" href="{{ path('app_admin_home') }}">
					⚙️ Admin Oumi
				</a>

				<div>

					<a class="btn btn-sm btn-light me-2" href="{{ path('app_visitor_welcome') }}">
						Retour au site
					</a>

					<a class="btn btn-sm btn-danger" href="{{ path('app_logout') }}">
						Déconnexion
					</a>

				</div>

			</div>

		</header>


		<div class="container-fluid">

			<div
				class="row">


				{# SIDEBAR #}

				<nav class="col-md-3 col-lg-2 sidebar">

					<div class="pt-3">

						<ul class="nav flex-column">

							<li class="nav-item">
								<a class="nav-link active" href="{{ path('app_admin_home') }}">
									<i class="fa-solid fa-house"></i>
									Dashboard
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_category_index') }}">
									<i class="fa-solid fa-folder"></i>
									Catégories
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_post_index') }}">
									<i class="fa-solid fa-feather"></i>
									Articles
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_tag_index') }}">
									<i class="fa-solid fa-tags"></i>
									Tags
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_contact_index') }}">
									<i class="fa-solid fa-envelope"></i>
									Contacts
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_user_index') }}">
									<i class="fa-solid fa-users"></i>
									Utilisateurs
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_comment_index') }}">
									<i class="fa-solid fa-comments"></i>
									Commentaires
								</a>
							</li>

						</ul>


						<div class="sidebar-title">
							<i class="fa-solid fa-store"></i>
							BOUTIQUE
						</div>

						<ul class="nav flex-column">

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_product_index') }}">
									<i class="fa-solid fa-leaf"></i>
									Produits
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_order_index') }}">
									<i class="fa-solid fa-basket-shopping"></i>
									Commandes
								</a>
							</li>

						</ul>


						<hr>

						<ul class="nav flex-column">

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_profile_index') }}">
									<i class="fa-solid fa-user"></i>
									Mon profil
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_admin_setting_index') }}">
									<i class="fa-solid fa-gear"></i>
									Paramètres
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_user_home') }}">
									<i class="fa-solid fa-house-user"></i>
									Espace utilisateur
								</a>
							</li>

						</ul>

					</div>

				</nav>


				{# MAIN CONTENT #}

				<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4"> {% block main %}{% endblock %}

					</main>

				</div>

			</div>

		</body>

	</html>
