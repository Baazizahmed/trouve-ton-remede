{% extends 'themes/base_admin.html.twig' %}

{% block title %}Gestion des Produits{% endblock %}

{% block main %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des Produits</h1>
        <a href="{{ path('app_admin_product_new') }}" class="btn btn-primary">
            + Nouveau produit
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Image</th>
                <th>Nom</th>
                <th>Slug</th>
                <th>Prix HT</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td>
                    {% if product.imageName %}
                        <img
                            src="{{ asset('images/dynamic/products/' ~ product.imageName) }}"
                            alt="{{ product.name }}"
                            style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px;"
                        >
                    {% else %}
                        <span class="text-muted">Aucune image</span>
                    {% endif %}
                </td>
                <td>{{ product.name }}</td>
                <td>{{ product.slug }}</td>
                <td>{{ product.price }} €</td>
                <td>
                    <a href="{{ path('app_admin_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-warning">
                        Modifier
                    </a>
                    <form action="{{ path('app_admin_product_delete', {'id': product.id}) }}" method="post" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                        <button type="submit" class="btn btn-sm btn-danger"
                            onclick="return confirm('Supprimer ce produit ?')">
                            Supprimer
                        </button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6">Aucun produit.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
