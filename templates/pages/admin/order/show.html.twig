{% extends 'themes/base_admin.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}

{% block main %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Commande #{{ order.id }}</h1>
        <a href="{{ path('app_admin_order_index') }}" class="btn btn-secondary">
            Retour liste
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="card mb-4">
        <div class="card-body">
            <p><strong>Client :</strong> {{ order.user.email }}</p>
            <p><strong>Date :</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>
            <p><strong>Sous-total HT :</strong> {{ order.subtotalHt|number_format(2, ',', ' ') }} €</p>
            <p><strong>TVA :</strong> {{ order.taxAmount|number_format(2, ',', ' ') }} €</p>
            <p><strong>Total TTC :</strong> {{ order.totalTtc|number_format(2, ',', ' ') }} €</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <strong>Modifier le statut</strong>
        </div>
        <div class="card-body">
            <form action="{{ path('app_admin_order_status', {'id': order.id}) }}" method="post" class="d-flex gap-2">
                <select name="status" class="form-select w-auto">
                    <option value="PENDING" {{ order.status == 'PENDING' ? 'selected' : '' }}>PENDING</option>
                    <option value="PAID" {{ order.status == 'PAID' ? 'selected' : '' }}>PAID</option>
                    <option value="SHIPPED" {{ order.status == 'SHIPPED' ? 'selected' : '' }}>SHIPPED</option>
                    <option value="CANCELLED" {{ order.status == 'CANCELLED' ? 'selected' : '' }}>CANCELLED</option>
                </select>
                <button type="submit" class="btn btn-warning">Mettre à jour</button>
            </form>
        </div>
    </div>

    <h3>Articles</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix HT</th>
                <th>TVA</th>
                <th>Total TTC</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
            <tr>
                <td>{{ item.productName }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.unitPriceHt }} €</td>
                <td>{{ item.taxRate }} %</td>
                <td>{{ item.totalTtc|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
