{% extends 'themes/base_admin.html.twig' %}

{% block title %}Gestion des Commandes{% endblock %}

{% block main %}
<div class="container-fluid mt-4">
    <h1>Gestion des Commandes</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <table class="table table-striped">
        <thead>
            <tr>
                <th>N°</th>
                <th>Client</th>
                <th>Date</th>
                <th>Total TTC</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
            <tr>
                <td>#{{ order.id }}</td>
                <td>{{ order.user.email }}</td>
                <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                <td>{{ order.totalTtc|number_format(2, ',', ' ') }} €</td>
                <td>
                    <span class="badge bg-{{ order.status == 'PENDING' ? 'warning' : (order.status == 'PAID' ? 'success' : (order.status == 'SHIPPED' ? 'info' : 'danger')) }}">
                        {{ order.status }}
                    </span>
                </td>
                <td>
                    <a href="{{ path('app_admin_order_show', {'id': order.id}) }}" class="btn btn-sm btn-primary">
                        Voir
                    </a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6">Aucune commande.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
