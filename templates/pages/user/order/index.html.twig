{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Mes commandes{% endblock %}

{% block description %}
Consultez l’historique de vos commandes de plantes médicinales.
{% endblock %}

{% block main %}
    {% include 'components/visitor/header-visitor.html.twig' with {
        h1: 'Mes commandes',
        subtitle: 'Retrouvez le détail de vos achats passés auprès d’Oumi.'
    } %}

    <section class="py-5 section-orders">
        <div class="container">

            {% if orders is empty %}
                <div class="card shadow-sm border-0 orders-empty-card">
                    <div class="card-body text-center py-5">
                        <h2 class="h5 fw-bold mb-3">Vous n’avez pas encore de commandes</h2>
                        <p class="text-muted mb-4">
                            Commencez par découvrir les plantes d’Oumi pour créer votre première commande.
                        </p>
                        <a href="{{ path('app_visitor_product_index') }}" class="btn btn-cta">
                            Voir les plantes
                        </a>
                    </div>
                </div>
            {% else %}
                <div class="card shadow-sm border-0 orders-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h2 class="h5 fw-bold mb-0">Historique de vos commandes</h2>
                            <span class="text-muted small">
                                {{ orders|length }} commande{{ orders|length > 1 ? 's' : '' }}
                            </span>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle orders-table mb-0">
                                <thead>
                                    <tr>
                                        <th>N° commande</th>
                                        <th>Date</th>
                                        <th class="text-end">Total TTC</th>
                                        <th>Statut</th>
                                        <th class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for order in orders %}
                                        <tr>
                                            <td>#{{ order.id }}</td>
                                            <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                                            <td class="text-end">
                                                {{ order.totalTtc|number_format(2, ',', ' ') }} €
                                            </td>
                                            <td>
                                                <span class="badge
                                                    {% if order.status == 'PENDING' %}
                                                        bg-warning text-dark
                                                    {% elseif order.status == 'CANCELLED' %}
                                                        bg-danger
                                                    {% else %}
                                                        bg-success
                                                    {% endif %}">
                                                    {{ order.status }}
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <a href="{{ path('app_order_show', {'id': order.id}) }}"
                                                   class="btn btn-sm btn-outline-primary">
                                                    Voir le détail
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            {% endif %}

        </div>
    </section>
{% endblock %}
