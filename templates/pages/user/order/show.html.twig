{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}

{% block main %}
<div class="container mt-4">
    <h1>Commande #{{ order.id }}</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="card mb-4">
        <div class="card-body">
            <p><strong>Statut :</strong> {{ order.status }}</p>
            <p><strong>Date :</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>
            <p><strong>Total TTC :</strong> {{ order.totalTtc|number_format(2, ',', ' ') }} €</p>
        </div>
    </div>

    <h3>Articles commandés</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix HT</th>
                <th>TVA</th>
                <th>Total TTC</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
            <tr>
                <td>{{ item.productName }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.unitPriceHt }} €</td>
                <td>{{ item.taxRate }} %</td>
                <td>{{ item.totalTtc|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-end fw-bold">Sous-total HT :</td>
                <td colspan="2">{{ order.subtotalHt|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td colspan="3" class="text-end fw-bold">TVA :</td>
                <td colspan="2">{{ order.taxAmount|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td colspan="3" class="text-end fw-bold">Total TTC :</td>
                <td colspan="2" class="fw-bold">{{ order.totalTtc|number_format(2, ',', ' ') }} €</td>
            </tr>
        </tfoot>
    </table>

    <a href="{{ path('app_order_index') }}" class="btn btn-outline-secondary">
        Mes commandes
    </a>
    <a href="{{ path('app_visitor_product_index') }}" class="btn btn-primary">
        Continuer mes achats
    </a>
</div>
{% endblock %}
