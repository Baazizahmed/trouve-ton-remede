{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}

{% block description %}
Détail de votre commande de plantes médicinales.
{% endblock %}

{% block main %}
    {% include 'components/visitor/header-visitor.html.twig' with {
        h1: 'Commande ' ~ '<span class="order-number">#' ~ order.id ~ '</span>',
        subtitle: 'Retrouvez le détail de votre commande de plantes et les montants associés.'
    } %}

    <section class="py-5 section-order-show">
        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success mb-3">{{ message }}</div>
            {% endfor %}

            <div class="row">
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0 order-card mb-4">
                        <div class="card-body">
                            <h2 class="h5 fw-bold mb-3">
                                Informations de la commande
                                <span class="order-number ms-2">#{{ order.id }}</span>
                            </h2>

                            <p class="mb-1">
                                <strong>Statut :</strong>
                                <span class="badge
                                    {% if order.status == 'PENDING' %}
                                        bg-warning text-dark
                                    {% elseif order.status == 'CANCELLED' %}
                                        bg-danger
                                    {% else %}
                                        bg-success
                                    {% endif %}">
                                    {{ order.status }}
                                </span>
                            </p>
                            <p class="mb-1">
                                <strong>Date :</strong>
                                {{ order.createdAt|date('d/m/Y H:i') }}
                            </p>
                            <p class="mb-0">
                                <strong>Total TTC :</strong>
                                {{ order.totalTtc|number_format(2, ',', ' ') }} €
                            </p>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 order-card">
                        <div class="card-body">
                            <h2 class="h5 fw-bold mb-3">Articles commandés</h2>

                            <div class="table-responsive">
                                <table class="table align-middle order-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Produit</th>
                                            <th class="text-center">Quantité</th>
                                            <th class="text-end">Prix HT</th>
                                            <th class="text-center">TVA</th>
                                            <th class="text-end">Total TTC</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for item in order.orderItems %}
                                            <tr>
                                                <td>{{ item.productName }}</td>
                                                <td class="text-center">{{ item.quantity }}</td>
                                                <td class="text-end">
                                                    {{ item.unitPriceHt|number_format(2, ',', ' ') }} €
                                                </td>
                                                <td class="text-center">{{ item.taxRate }} %</td>
                                                <td class="text-end">
                                                    {{ item.totalTtc|number_format(2, ',', ' ') }} €
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold">Sous-total HT :</td>
                                            <td colspan="2" class="text-end">
                                                {{ order.subtotalHt|number_format(2, ',', ' ') }} €
                                            </td>
                                        </tr>
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold">TVA :</td>
                                            <td colspan="2" class="text-end">
                                                {{ order.taxAmount|number_format(2, ',', ' ') }} €
                                            </td>
                                        </tr>
                                        <tr>
                                            <td colspan="3" class="text-end fw-bold">Total TTC :</td>
                                            <td colspan="2" class="text-end fw-bold">
                                                {{ order.totalTtc|number_format(2, ',', ' ') }} €
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-wrap gap-2">
                        <a href="{{ path('app_order_index') }}" class="btn btn-outline-secondary">
                            ← Mes commandes
                        </a>
                        <a href="{{ path('app_visitor_product_index') }}" class="btn btn-cta">
                            Continuer mes achats
                        </a>
                    </div>
                </div>

                {# Colonne latérale : rappel synthétique #}
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card shadow-sm border-0 order-summary">
                        <div class="card-body">
                            <h2 class="h6 fw-bold mb-3">Résumé</h2>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Sous-total HT</span>
                                <span>{{ order.subtotalHt|number_format(2, ',', ' ') }} €</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">TVA</span>
                                <span>{{ order.taxAmount|number_format(2, ',', ' ') }} €</span>
                            </div>

                            <hr>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="fw-bold">Total TTC</span>
                                <span class="fw-bold">
                                    {{ order.totalTtc|number_format(2, ',', ' ') }} €
                                </span>
                            </div>

                            <p class="form-text text-muted mt-3 mb-0">
                                Conservez cette page ou l’email de confirmation pour vos archives.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>
{% endblock %}
