{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block description %}
Retrouvez les plantes que vous avez ajoutées à votre panier avant de finaliser votre commande.
{% endblock %}

{% block main %}
    {% include 'components/visitor/header-visitor.html.twig' with {
        h1: 'Mon panier',
        subtitle: 'Vérifiez vos plantes et ajustez les quantités avant la commande.'
    } %}

    <section class="py-5 section-cart">
        <div class="container">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success mb-3">{{ message }}</div>
            {% endfor %}

            {% if cart.cartItems is empty %}
                <div class="card shadow-sm border-0 cart-empty-card">
                    <div class="card-body text-center py-5">
                        <h2 class="h5 fw-bold mb-3">Votre panier est vide</h2>
                        <p class="text-muted mb-4">
                            Ajoutez des plantes à votre panier pour commencer votre cure bien-être.
                        </p>
                        <a href="{{ path('app_visitor_product_index') }}" class="btn btn-cta">
                            Découvrir les plantes
                        </a>
                    </div>
                </div>
            {% else %}
                <div class="row">
                    <div class="col-lg-8">
                        <div class="card shadow-sm border-0 cart-card mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h2 class="h5 fw-bold mb-0">Vos plantes</h2>
                                    <span class="text-muted small">
                                        {{ cart.cartItems|length }} article{{ cart.cartItems|length > 1 ? 's' : '' }}
                                    </span>
                                </div>

                                <div class="table-responsive">
                                    <table class="table align-middle cart-table mb-0">
                                        <thead>
                                            <tr>
                                                <th>Produit</th>
                                                <th class="text-end">Prix unitaire</th>
                                                <th class="text-center">Quantité</th>
                                                <th class="text-end">Total</th>
                                                <th class="text-center">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for item in cart.cartItems %}
                                                <tr>
                                                    <td>{{ item.product.name }}</td>
                                                    <td class="text-end">
                                                        {{ item.unitPrice|number_format(2, ',', ' ') }} €
                                                    </td>
                                                    <td class="text-center">
                                                        <form action="{{ path('app_cart_update', {'id': item.id}) }}"
                                                              method="post"
                                                              class="d-inline-flex align-items-center gap-2 justify-content-center">
                                                            <input type="number"
                                                                   name="quantity"
                                                                   value="{{ item.quantity }}"
                                                                   min="1"
                                                                   class="form-control form-control-sm cart-qty-input">
                                                            <button type="submit"
                                                                    class="btn btn-sm btn-outline-success">
                                                                Modifier
                                                            </button>
                                                        </form>
                                                    </td>
                                                    <td class="text-end">
                                                        {{ (item.unitPrice * item.quantity)|number_format(2, ',', ' ') }} €
                                                    </td>
                                                    <td class="text-center">
                                                        <form action="{{ path('app_cart_remove', {'id': item.id}) }}"
                                                              method="post" class="d-inline">
                                                            <button type="submit"
                                                                    class="btn btn-sm btn-outline-danger">
                                                                Supprimer
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>

                        <a href="{{ path('app_visitor_product_index') }}" class="btn btn-outline-secondary">
                            ← Continuer mes achats
                        </a>
                    </div>

                    <div class="col-lg-4 mt-4 mt-lg-0">
                        <div class="card shadow-sm border-0 cart-summary">
                            <div class="card-body">
                                <h2 class="h5 fw-bold mb-3">Résumé de la commande</h2>

                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Sous-total</span>
                                    <span>{{ total|number_format(2, ',', ' ') }} €</span>
                                </div>

                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted small">TVA incluse</span>
                                    <span class="small text-muted">Selon taux en vigueur</span>
                                </div>

                                <hr>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="fw-bold">Total à payer</span>
                                    <span class="fw-bold">
                                        {{ total|number_format(2, ',', ' ') }} €
                                    </span>
                                </div>

                                <form action="{{ path('app_order_validate') }}" method="post" class="d-grid gap-2">
                                    <button type="submit" class="btn btn-cta btn-lg">
                                        Valider la commande
                                    </button>
                                    <p class="form-text text-muted mb-0 text-center">
                                        Le paiement est 100 % sécurisé. Vous pourrez vérifier vos informations
                                        avant de confirmer.
                                    </p>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
