{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block description %}
Retrouvez les plantes que vous avez ajoutées à votre panier avant de finaliser votre commande.
{% endblock %}

{% block main %}

{% include 'components/visitor/header-visitor.html.twig' with {
    h1: 'Mon panier',
    subtitle: 'Vérifiez vos plantes et ajustez les quantités avant la commande.'
} %}

<section class="py-5 section-cart">
    <div class="container">

        {# FLASH MESSAGE #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success shadow-sm border-0 rounded-4 mb-4">
                {{ message }}
            </div>
        {% endfor %}

        {% if cart.cartItems is empty %}

            {# PANIER VIDE #}
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden cart-empty-card">
                <div class="card-body text-center py-5 px-4">

                    <div class="cart-empty-icon mb-4">
                        🛒
                    </div>

                    <h2 class="fw-bold mb-3">
                        Votre panier est vide
                    </h2>

                    <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">
                        Découvrez notre sélection de plantes médicinales, nos cures bien-être
                        et nos conseils pour prendre soin de vous naturellement.
                    </p>

                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a href="{{ path('app_visitor_product_index') }}"
                           class="btn btn-success btn-lg px-4 rounded-pill shadow-sm">
                            Voir les plantes
                        </a>

                        <a href="{{ path('app_visitor_blog_index') }}"
                           class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                            Lire les conseils
                        </a>
                    </div>

                </div>
            </div>

        {% else %}

            <div class="row g-4">

                {# PRODUITS #}
                <div class="col-lg-8">

                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden cart-card">

                        <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">

                            <div>
                                <h2 class="h4 fw-bold mb-1">
                                    Vos plantes
                                </h2>

                                <p class="text-muted small mb-0">
                                    Vérifiez votre sélection avant de valider la commande.
                                </p>
                            </div>

                            <span class="badge rounded-pill text-bg-success px-3 py-2">
                                {{ cart.cartItems|length }}
                                article{{ cart.cartItems|length > 1 ? 's' : '' }}
                            </span>

                        </div>

                        <div class="card-body p-0">

                            <div class="table-responsive">

                                <table class="table align-middle mb-0 cart-table">

                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">Produit</th>
                                            <th class="text-end">Prix unitaire</th>
                                            <th class="text-center">Quantité</th>
                                            <th class="text-end">Total</th>
                                            <th class="text-center pe-4">Action</th>
                                        </tr>
                                    </thead>

                                    <tbody>

                                    {% for item in cart.cartItems %}

                                        <tr>

                                            {# PRODUIT #}
                                            <td class="ps-4 py-4">

                                                <div class="d-flex align-items-center gap-3">

                                                    {% if item.product.imageName %}
                                                        <img
                                                            src="{{ asset('images/dynamic/products/' ~ item.product.imageName) }}"
                                                            alt="{{ item.product.name }}"
                                                            class="rounded-3 shadow-sm"
                                                            style="width: 70px; height: 70px; object-fit: cover;"
                                                        >
                                                    {% endif %}

                                                    <div>
                                                        <h3 class="h6 fw-bold mb-1">
                                                            {{ item.product.name }}
                                                        </h3>

                                                        <p class="small text-muted mb-0">
                                                            Produit naturel sélectionné par Oumi
                                                        </p>
                                                    </div>

                                                </div>

                                            </td>

                                            {# PRIX #}
                                            <td class="text-end fw-semibold">
                                                {{ item.unitPrice|number_format(2, ',', ' ') }} €
                                            </td>

                                            {# QUANTITE #}
                                            <td class="text-center">

                                                <form
                                                    action="{{ path('app_cart_update', {'id': item.id}) }}"
                                                    method="post"
                                                    class="d-inline-flex align-items-center gap-2 justify-content-center"
                                                >

                                                    <input
                                                        type="number"
                                                        name="quantity"
                                                        value="{{ item.quantity }}"
                                                        min="1"
                                                        class="form-control text-center"
                                                        style="width: 80px;"
                                                    >

                                                    <button
                                                        type="submit"
                                                        class="btn btn-sm btn-outline-success rounded-pill"
                                                    >
                                                        Mettre à jour
                                                    </button>

                                                </form>

                                            </td>

                                            {# TOTAL #}
                                            <td class="text-end fw-bold text-success">
                                                {{ (item.unitPrice * item.quantity)|number_format(2, ',', ' ') }} €
                                            </td>

                                            {# SUPPRIMER #}
                                            <td class="text-center pe-4">

                                                <form
                                                    action="{{ path('app_cart_remove', {'id': item.id}) }}"
                                                    method="post"
                                                    class="d-inline"
                                                >

                                                    <button
                                                        type="submit"
                                                        class="btn btn-sm btn-outline-danger rounded-pill"
                                                    >
                                                        Supprimer
                                                    </button>

                                                </form>

                                            </td>

                                        </tr>

                                    {% endfor %}

                                    </tbody>

                                </table>

                            </div>

                        </div>

                    </div>

                    <div class="mt-4">
                        <a href="{{ path('app_visitor_product_index') }}"
                           class="btn btn-outline-secondary rounded-pill px-4">
                            ← Continuer mes achats
                        </a>
                    </div>

                </div>

                {# RESUME #}
                <div class="col-lg-4">

                    <div class="card border-0 shadow-lg rounded-4 cart-summary sticky-top"
                         style="top: 100px;">

                        <div class="card-body p-4">

                            <h2 class="h4 fw-bold mb-4">
                                Résumé de la commande
                            </h2>

                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">
                                    Sous-total
                                </span>

                                <span class="fw-semibold">
                                    {{ total|number_format(2, ',', ' ') }} €
                                </span>
                            </div>

                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">
                                    Livraison
                                </span>

                                <span class="text-success fw-semibold">
                                    Offerte
                                </span>
                            </div>

                            <div class="d-flex justify-content-between mb-4">
                                <span class="text-muted">
                                    TVA
                                </span>

                                <span class="small text-muted">
                                    Incluse
                                </span>
                            </div>

                            <hr>

                            <div class="d-flex justify-content-between align-items-center mb-4">

                                <span class="fw-bold fs-5">
                                    Total à payer
                                </span>

                                <span class="fw-bold fs-4 text-success">
                                    {{ total|number_format(2, ',', ' ') }} €
                                </span>

                            </div>

                            {# BTN VALIDATION #}
                            <form action="{{ path('app_order_validate') }}"
                                  method="post"
                                  class="d-grid">

                                <button
                                    type="submit"
                                    class="btn btn-success btn-lg rounded-pill shadow-sm"
                                >
                                    Valider ma commande
                                </button>

                            </form>

                            <p class="small text-muted text-center mt-3 mb-0">
                                Paiement sécurisé • Livraison suivie • Service client disponible
                            </p>

                            {# AVANTAGES #}
                            <div class="mt-4 pt-4 border-top">

                                <div class="d-flex align-items-start gap-3 mb-3">
                                    <span>🌿</span>
                                    <small>
                                        Plantes et produits naturels sélectionnés avec soin
                                    </small>
                                </div>

                                <div class="d-flex align-items-start gap-3 mb-3">
                                    <span>🚚</span>
                                    <small>
                                        Livraison soignée et emballage adapté
                                    </small>
                                </div>

                                <div class="d-flex align-items-start gap-3">
                                    <span>💬</span>
                                    <small>
                                        Informations et conseils bien-être sur notre blog
                                    </small>
                                </div>

                            </div>

                            {# MINI CTA #}
                            <div class="mt-4 p-3 rounded-4 bg-light">

                                <p class="fw-bold mb-2">
                                    Besoin d’inspiration ?
                                </p>

                                <p class="small text-muted mb-3">
                                    Découvrez nos plantes les plus appréciées et nos articles pour construire votre routine bien-être.
                                </p>

                                <div class="d-grid gap-2">

                                    <a href="{{ path('app_visitor_product_index') }}"
                                       class="btn btn-outline-success btn-sm rounded-pill">
                                        Voir les plantes
                                    </a>

                                    <a href="{{ path('app_visitor_blog_index') }}"
                                       class="btn btn-outline-secondary btn-sm rounded-pill">
                                        Lire les conseils
                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        {% endif %}
    </div>
</section>

{% endblock %}