{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Accueil{% endblock %}
{% block description %}Boutique de plantes médicinales naturelles – TrouveTonRemede{% endblock %}

{% block main %}

<section class="hero py-5">
    <div class="container">
        <div class="row align-items-center g-4">

            <div class="col-md-6 text-center text-md-start">
                <span class="badge px-3 py-2 rounded-pill bg-success-subtle text-success mb-3">
                    🌿 Plantes médicinales sélectionnées avec soin
                </span>

                <h1 class="display-5 fw-bold mb-3">
                    Prenez soin de vous naturellement avec les plantes d’Oumi
                </h1>

                <p class="lead mb-4">
                    Découvrez une sélection de plantes choisies avec attention pour accompagner
                    le sommeil, la digestion, l’immunité et le bien-être au quotidien,
                    avec des conseils simples et accessibles.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-3">
                    <a href="{{ path('app_visitor_product_index') }}" class="btn btn-cta btn-lg">
                        🛒 Découvrir les plantes
                    </a>

                    <a href="{{ path('app_visitor_blog_index') }}" class="btn btn-outline-success btn-lg">
                        Lire les conseils
                    </a>
                </div>

                <p class="small text-muted mt-3 mb-0">
                    Produits naturels sélectionnés avec soin • Livraison soignée • Conseils bien-être simples
                </p>
            </div>

            <div class="col-md-6 text-center">
                <img
                    src="/images/static/welcome/TrouveTonRemede1.png"
                    class="img-fluid hero-image"
                    alt="Sélection de plantes médicinales naturelles TrouveTonRemede"
                >
            </div>

        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
        <div class="row g-3 text-center">

            <div class="col-md-4">
                <div class="p-3 rounded-4 bg-light h-100">
                    <div class="mb-2 fs-4">🌿</div>
                    <h2 class="h6 fw-bold mb-2">Une sélection utile</h2>
                    <p class="small text-muted mb-0">
                        Des plantes choisies pour répondre à des besoins concrets du quotidien.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-3 rounded-4 bg-light h-100">
                    <div class="mb-2 fs-4">💬</div>
                    <h2 class="h6 fw-bold mb-2">Des conseils accessibles</h2>
                    <p class="small text-muted mb-0">
                        Oumi partage des conseils simples pour mieux comprendre les usages traditionnels.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-3 rounded-4 bg-light h-100">
                    <div class="mb-2 fs-4">🚚</div>
                    <h2 class="h6 fw-bold mb-2">Une expérience rassurante</h2>
                    <p class="small text-muted mb-0">
                        Commande simple, livraison soignée et accompagnement en cas de besoin.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="section-plantes py-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <div>
                <h2 class="section-title mb-2">
                    🌿 Les plantes les plus appréciées
                </h2>

                <p class="section-subtitle mb-0">
                    Une première sélection pour accompagner le sommeil, la digestion,
                    le confort respiratoire et l’énergie naturelle.
                </p>
            </div>

            <a href="{{ path('app_visitor_product_index') }}" class="btn btn-outline-success">
                Voir toute la boutique
            </a>
        </div>

        {% if featuredProducts is not empty %}
            <div class="row g-4">
                {% for product in featuredProducts %}
                    <div class="col-lg-3 col-md-4 col-sm-6">

                        <article class="card-produit h-100">

                            {% if product.imageName %}
                                <div class="card-produit__image-wrapper">
                                    <img
                                        src="{{ asset('images/dynamic/products/' ~ product.imageName) }}"
                                        class="card-produit__image"
                                        alt="{{ product.name }}"
                                    >
                                </div>
                            {% endif %}

                            <div class="card-produit__body">
                                <h3 class="card-produit__title h5">
                                    {{ product.name }}
                                </h3>

                                <p class="card-produit__excerpt">
                                    {{ product.description|u.truncate(90, '...') }}
                                </p>

                                <div class="card-produit__footer">
                                    <span class="card-produit__price">
                                        {{ product.price|number_format(2, ',', ' ') }} €
                                    </span>

                                    <a href="{{ path('app_visitor_product_show', { slug: product.slug }) }}"
                                       class="btn btn-sm btn-primary">
                                        Voir
                                    </a>
                                </div>
                            </div>

                        </article>

                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-center text-muted mb-0">
                Les plantes seront bientôt disponibles.
            </p>
        {% endif %}
    </div>
</section>

<section class="section-oumi py-5">
    <div class="container">
        <div class="row align-items-center g-4">

            <div class="col-md-5 text-center">
                <img
                    src="/images/static/welcome/about.jpg"
                    class="img-fluid shadow-sm rounded-4"
                    alt=""
                >
            </div>

            <div class="col-md-7">
                <span class="badge px-3 py-2 rounded-pill bg-light text-success mb-3">
                    Une approche simple et naturelle
                </span>

                <h2 class="fw-bold mb-3">
                    Oumi partage une tradition de bien-être transmise avec le cœur
                </h2>

                <p>
                    Passionnée par les plantes médicinales depuis l’enfance, Oumi a grandi
                    dans une culture où les remèdes naturels faisaient partie du quotidien.
                </p>

                <p>
                    Sur <strong>TrouveTonRemede</strong>, elle partage une sélection de plantes,
                    des conseils accessibles et une approche bienveillante pour vous aider
                    à trouver des solutions naturelles adaptées à vos besoins.
                </p>

                <a href="{{ path('app_visitor_blog_index') }}" class="btn btn-outline-success mt-2">
                    Découvrir les articles
                </a>
            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="h3 fw-bold mb-3">
                🌿 Conseils et bien-être naturel
            </h2>
            <p class="text-muted mb-0">
                Des articles simples pour mieux comprendre les plantes et leurs usages traditionnels.
            </p>
        </div>

        <div class="row g-4">
            {% for post in posts %}
                <div class="col-md-4">

                    <article class="card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-body d-flex flex-column">

                            <h3 class="h5 mb-2">
                                {{ post.title|u.truncate(60, '...') }}
                            </h3>

                            <p class="small text-muted mb-1">
                                Catégorie : {{ post.category.name }}
                            </p>

                            <p class="small text-muted mb-3">
                                Publié {{ post.publishedAt|ago() }}
                            </p>

                            <a href="{{ path('app_visitor_blog_post_show', {
                                id: post.id,
                                slug: post.slug
                            }) }}"
                               class="btn btn-outline-primary mt-auto">
                                Lire l'article
                            </a>

                        </div>
                    </article>

                </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-5 text-center">
    <div class="container">

        <h2 class="h4 mb-3">
            Besoin d’un conseil pour choisir une plante ?
        </h2>

        <p class="text-muted mb-4">
            Oumi peut vous orienter vers les plantes les plus adaptées à votre besoin et à votre routine.
        </p>

        <a href="{{ path('app_visitor_contact_create') }}" class="btn btn-lg btn-primary">
            📩 Contacter Oumi
        </a>

    </div>
</section>

{% endblock %}