{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block description %}Découvrez les plantes médicinales naturelles d’Oumi{% endblock %}

{% block main %}

{# HERO SECTION #}
<header class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-md-6 text-center text-md-start">
                <h1 class="display-4 fw-bold mb-4">
                    🌿 Le bienfait des plantes pour votre bien-être
                </h1>

                <p class="lead text-muted">
                    Découvrez les remèdes naturels d’Oumi : des plantes médicinales
                    sélectionnées avec soin pour prendre soin de votre santé
                    de manière naturelle et durable.
                </p>

                <div class="mt-4">
                    <a href="{{ path('app_visitor_product_index') }}"
                       class="btn btn-success btn-lg shadow me-2">
                        🌿 Découvrir la boutique
                    </a>

                    <a href="{{ path('app_visitor_blog_index') }}"
                       class="btn btn-outline-primary btn-lg">
                        Lire les conseils
                    </a>
                </div>
            </div>

            <div class="col-md-6 text-center mt-4 mt-md-0">
                <img src="/images/static/welcome/Nature.png"
                     class="img-fluid"
                     alt="Plantes médicinales naturelles">
            </div>

        </div>
    </div>
</header>


{# ABOUT SECTION #}
<section class="py-5">
    <div class="container">

        <h2 class="text-center display-6 mb-5">
            🌿 Qui est Oumi ?
        </h2>

        <div class="row align-items-center">

            <div class="col-md-6 text-center">
                <img src="/images/static/welcome/about.png"
                     class="img-fluid rounded shadow"
                     alt="Oumi experte en plantes médicinales">
            </div>

            <div class="col-md-6">

                <p class="mb-3">
                    Passionnée par les plantes médicinales depuis l’enfance,
                    Oumi a grandi dans une culture où les remèdes naturels
                    faisaient partie du quotidien.
                </p>

                <p class="mb-3">
                    Après une formation spécialisée, elle partage aujourd’hui
                    ses connaissances pour aider chacun à prendre soin
                    de sa santé grâce aux bienfaits des plantes.
                </p>

                <p class="mb-4">
                    Sur ce blog et cette boutique, vous trouverez
                    des conseils, des recettes naturelles
                    et une sélection de plantes soigneusement choisies.
                </p>

                <a href="{{ path('app_visitor_blog_index') }}"
                   class="btn btn-outline-success">
                   Découvrir les articles
                </a>

            </div>

        </div>

    </div>
</section>


{# PRODUITS MIS EN AVANT #}
<section class="py-5 bg-light">

    <h2 class="text-center display-6 mb-5">
        🌿 Nos plantes médicinales populaires
    </h2>

    <div class="container">

        {% if featuredProducts is not empty %}

        <div class="row g-4">

            {% for product in featuredProducts %}

            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card h-100 shadow-sm border-0">

                    {% if product.imageName %}
                        <img
                            src="{{ asset('images/dynamic/products/' ~ product.imageName) }}"
                            class="card-img-top"
                            alt="{{ product.name }}"
                            style="height:220px; object-fit:cover;"
                        >
                    {% endif %}

                    <div class="card-body d-flex flex-column">

                        <h3 class="h6 fw-bold mb-2">
                            {{ product.name }}
                        </h3>

                        <p class="small text-muted mb-3 flex-grow-1">
                            {{ product.description|u.truncate(90,'...') }}
                        </p>

                        <div class="d-flex justify-content-between align-items-center">

                            <span class="fw-bold text-success fs-5">
                                {{ product.price|number_format(2, ',', ' ') }} €
                            </span>

                            <a href="{{ path('app_visitor_product_show',{slug:product.slug}) }}"
                               class="btn btn-sm btn-success">
                               Voir
                            </a>

                        </div>

                    </div>

                </div>

            </div>

            {% endfor %}

        </div>

        <div class="text-center mt-5">
            <a href="{{ path('app_visitor_product_index') }}"
               class="btn btn-lg btn-success shadow">
               🌿 Voir toute la boutique
            </a>
        </div>

        {% else %}

        <p class="text-center text-muted">
            Les plantes seront bientôt disponibles.
        </p>

        {% endif %}

    </div>

</section>


{# ARTICLES RECENTS #}
<section class="py-5">

<h2 class="text-center display-6 mb-5">
🌿 Conseils et bien-être naturel
</h2>

<div class="container">

<div class="row g-4">

{% for post in posts %}

<div class="col-md-4">

<div class="card h-100 shadow-sm">

<div class="card-body d-flex flex-column">

<h3 class="h5 mb-3">
{{ post.title|u.truncate(60,'...') }}
</h3>

<p class="small text-muted">
Catégorie : {{ post.category.name }}
</p>

<p class="small text-muted">
Publié {{ post.publishedAt|ago() }}
</p>

<a href="{{ path('app_visitor_blog_post_show',{'id':post.id,'slug':post.slug}) }}"
   class="btn btn-outline-primary mt-auto">
   Lire l'article
</a>

</div>

</div>

</div>

{% endfor %}

</div>

</div>

</section>


{# CONTACT / CTA #}
<section class="py-5 text-center bg-light">

<h2 class="mb-3">
Besoin de conseils personnalisés ?
</h2>

<p class="text-muted mb-4">
Oumi peut vous guider dans le choix des plantes adaptées à votre besoin.
</p>

<a href="{{ path('app_visitor_contact_create') }}"
   class="btn btn-lg btn-primary shadow">
   📩 Contacter Oumi
</a>

</section>

{% endblock %}