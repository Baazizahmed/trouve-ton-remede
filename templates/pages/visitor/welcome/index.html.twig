{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block description %}Bienvenue sur le blog de Oumi
{% endblock %}

{% block main %}
	{# Hero-section #}
	<header class="py-3">
		<div class="container">
			<div class="row">
				<div class="col-md-5 order-md-2 d-flex justify-content-center align-items-center">
					<img src="/images/static/welcome/Nature.png" class="img-fluid" alt="Oumi souhantant la bienvenue sur son blog">
				</div>
				<div class="col-md-7 order-md-1 d-flex flex-column justify-content-evenly align-items-center">
					<h1 class="display-5 my-5">Bienvenue sur 🌿Oumi-blog !</h1>
					<div>
						<p>Oumi, exploratrice du bien-être par les plantes et la médecine douce.</p>
						<p>Enssemble, découvrons les clés pour une santé simple, durable et accessible à tous.</p>
					</div>

					<div class="mt-4">
						<a href="{{path('app_visitor_blog_index')}}" class="btn btn-lg btn-primary shadow">Liste des articles</a>
					</div>
				</div>
			</div>
		</div>
	</header>

	{# About-me section #}
	<section id="about-me" class="bg-light py-3">

		<h2 class="text-center my-3 display-5">🌿Qui suis-je ?</h2>

		<div class="container">
			<div class="row">
				<div class="col-md-6 d-flex justify-content-center align-items-center">
					<img src="/images/static/welcome/about.png" class="img-fluid" alt="A propos de Oumi">
				</div>
				<div class="col-md-6 d-flex flex-column justify-content-center align-items-center">
					<p>
						🌿Oumi est une passionnée des plantes médicinales depuis son plus jeune âge. Ayant grandi dans un environnement où les remèdes naturels étaient au cœur du quotidien, elle a développé une véritable affection pour les vertus des plantes. Son intérêt s'est transformé en une quête de connaissances approfondies, l'amenant à étudier les propriétés médicinales de diverses espèces végétales
					</p>
					<p>
						Après avoir suivi une formation spécialisée, Oumi est devenue une véritable experte dans le domaine des plantes médicinales. Elle consacre aujourd'hui son temps à partager ses connaissances avec le plus grand nombre, en offrant des conseils personnalisés et en animant des ateliers sur les bienfaits des plantes.
					</p>
					<p>
						À travers son blog, Oumi souhaite sensibiliser le public aux alternatives naturelles pour le bien-être. Elle y partage des recettes, des conseils pratiques, et des témoignages, le tout avec une touche personnelle et authentique.🌿
					</p>
				</div>
			</div>
		</div>
	</section>

	    {# Produits mis en avant #}
    <section class="py-4 bg-light">
        <h2 class="text-center my-3 display-5">🌿 Produits mis en avant</h2>

        <div class="container">
            {% if featuredProducts is not empty %}
                <div class="row g-4">
                    {% for product in featuredProducts %}
                        <div class="col-md-3 col-sm-6">
                            <div class="card h-100 shadow-sm">

                                <div class="card-body d-flex flex-column">
                                    <h3 class="h6 card-title mb-2">
                                        {{ product.name }}
                                    </h3>

                                    <p class="small text-muted mb-3 flex-grow-1">
                                        {{ product.description|u.truncate(80, '…') }}
                                    </p>

                                    <p class="fw-bold mb-3">
                                        {{ product.price|number_format(2, ',', ' ') }} €
                                    </p>

                                    <a href="{{ path('app_visitor_product_show', { slug: product.slug }) }}"
                                       class="btn btn-sm btn-outline-primary mt-auto">
                                        Découvrir ce produit
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="text-center mt-4">
                    <a href="{{ path('app_visitor_product_index') }}"
                       class="btn btn-lg btn-success shadow">
                        Voir toutes les plantes médicinales
                    </a>
                </div>
            {% else %}
                <p class="text-center text-muted mb-0">
                    Les produits seront bientôt disponibles sur la boutique.
                </p>
            {% endif %}
        </div>
    </section>


	{# Last-posts sections #}
	<section class="py-3">
		<h2 class="text-center my-3 display-5">🌿Mes derniers articles</h2>

		<div class="container">
			<div class="row">
				{% for post in posts %}
					<div class="col-md-4 mb-3">


						<div class="card h-100 shadow">
							<h3 class="card-header">
								{{post.title|u.truncate('50', '...')}}
							</h3>


							<div class="card-body d-flex flex-column">
								<p>
									<strong>Catégorie</strong>:
									{{post.category.name}}
								</p>

								{% if post.tags is not empty %}
									<p>
										<strong>Tags</strong>:
										{% for tag in post.tags %}
											<span class="mx-1 badge bg-secondary">{{tag.name}}</span>
										{% endfor %}
									</p>
								{% endif %}

								<p>
									Publié
									{{post.publishedAt|ago()}}
								</p>
								<a href="{{path('app_visitor_blog_post_show',{'id':post.id,'slug':post.slug})}}" class="btn btn-primary mt-auto">
									Lire l'article
								</a>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		</div>
	</section>


	{# Contact-section #}
	<div class="py-3 text-center bg-light">
		<a href="{{path('app_visitor_contact_create')}}" class="my-3 btn btn-lg btn-primary shadow">Contactez-moi</a>
	</div>

{% endblock %}

