{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Contactez-moi{% endblock %}

{% block description %}
Contactez-moi pour toute question sur les plantes, les commandes ou le bien-être.
{% endblock %}

{# Font awesome #}
{% block fontAwesome %}
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />
{% endblock %}

{% block main %}
    {% include 'components/visitor/header-visitor.html.twig' with {
        h1: 'Contactez Oumi',
        
    } %}

    <section class="py-5 section-contact">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="card shadow-sm border-0 contact-card">
                        <div class="row g-0">
                            {# Colonne formulaire #}
                            <div class="col-md-6">
                                <div class="card-body p-4 p-lg-5">

                                    <h2 class="h4 fw-bold mb-2">
                                        Écrivez à Oumi
                                    </h2>
                                    <p class="text-muted mb-3">
                                        Tous les champs marqués d’une astérisque sont obligatoires.
                                    </p>
                                    <p class="text-muted mb-4">
                                        Posez vos questions sur les plantes, les commandes ou votre situation,
                                        Oumi vous répondra rapidement.
                                    </p>

                                    {% include 'components/alert.html.twig' %}

                                    {{ form_start(form) }}
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label for="visitor_contact_form_firstName" class="form-label">
                                                    Prénom <span class="text-danger">*</span>
                                                </label>
                                                <div class="text-danger small">{{ form_errors(form.firstName) }}</div>
                                                {{ form_widget(form.firstName, {
                                                    attr: { class: 'form-control', autofocus: 'autofocus' }
                                                }) }}
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="visitor_contact_form_lastName" class="form-label">
                                                    Nom <span class="text-danger">*</span>
                                                </label>
                                                <div class="text-danger small">{{ form_errors(form.lastName) }}</div>
                                                {{ form_widget(form.lastName, {
                                                    attr: { class: 'form-control' }
                                                }) }}
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label for="visitor_contact_form_email" class="form-label">
                                                    Email <span class="text-danger">*</span>
                                                </label>
                                                <div class="text-danger small">{{ form_errors(form.email) }}</div>
                                                {{ form_widget(form.email, {
                                                    attr: { class: 'form-control' }
                                                }) }}
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="visitor_contact_form_phone" class="form-label">
                                                    Téléphone <span class="text-muted small">(optionnel)</span>
                                                </label>
                                                <div class="text-danger small">{{ form_errors(form.phone) }}</div>
                                                {{ form_widget(form.phone, {
                                                    attr: { class: 'form-control' }
                                                }) }}
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label for="visitor_contact_form_message" class="form-label">
                                                Message <span class="text-danger">*</span>
                                            </label>
                                            <div class="text-danger small">{{ form_errors(form.message) }}</div>
                                            {{ form_widget(form.message, {
                                                attr: { class: 'form-control', rows: 4 }
                                            }) }}
                                        </div>

                                        <div class="mt-3">
                                            <button type="submit" class="btn btn-cta w-100 w-md-auto">
                                                📩 Envoyer le message
                                            </button>
                                            <p class="form-text text-muted mt-2 mb-0">
                                                Vos données restent confidentielles, aucun spam, jamais.
                                            </p>
                                        </div>
                                    {{ form_end(form) }}

                                </div>
                            </div>

                            {# Colonne infos + carte #}
                            <div class="col-md-6 bg-light contact-aside">
                                <div class="h-100 d-flex flex-column p-4 p-lg-5">
                                    <h3 class="h5 fw-bold mb-3">
                                        Coordonnées et boutique
                                    </h3>

                                    <p class="mb-3">
                                        Pour toute question urgente, vous pouvez aussi utiliser les moyens
                                        de contact ci-dessous.
                                    </p>

                                    <ul class="list-unstyled mb-4">
                                        <li class="mb-2">
                                            <i class="fa-solid fa-envelope me-2 text-success"></i>
                                            {{ setting.email }}
                                        </li>
                                        {% if setting.phone is not empty %}
                                            <li class="mb-2">
                                                <i class="fa-solid fa-phone me-2 text-success"></i>
                                                {{ setting.phone }}
                                            </li>
                                        {% endif %}
                                    </ul>

                                    <div class="contact-map-wrapper mt-auto">
                                        <div class="contact-map-responsive">
                                            <iframe
                                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2626.6234710119184!2d2.3670098863940616!3d48.82724522898099!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47e673ad4924d833%3A0x8f50983162821f36!2sPlantes%20%26%20Sant%C3%A9!5e0!3m2!1sfr!2sfr!4v1749413087660!5m2!1sfr!2sfr"
                                                style="border:0;"
                                                allowfullscreen=""
                                                loading="lazy"
                                                referrerpolicy="no-referrer-when-downgrade">
                                            </iframe>
                                        </div>
                                    </div>

                                </div>
                            </div>

                        </div> {# .row g-0 #}
                    </div> {# .card #}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
