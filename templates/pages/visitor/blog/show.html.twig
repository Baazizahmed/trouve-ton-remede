{% extends 'themes/base_visitor.html.twig' %}

{% block title %}
    {{ post.title }} - TrouveTonRemede
{% endblock %}

{% block description %}
    {{ post.description }}
{% endblock %}

{% block fontAwesome %}
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
    />
{% endblock %}

{% block main %}
    <section class="blog-post-page py-5">
        <div class="container">

            <div class="row justify-content-center">
                <div class="col-lg-10">

                    <nav aria-label="breadcrumb" class="blog-post-breadcrumb mb-4">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a href="{{ path('app_visitor_blog_index') }}">
                                    Blog
                                </a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">
                                {{ post.title|u.truncate(60, '…') }}
                            </li>
                        </ol>
                    </nav>

                    <article class="blog-post-hero">

                        {% if post.image %}
                            <div class="blog-post-hero__image-wrap">
                                <img src="{{ vich_uploader_asset(post, 'imageFile') }}"
                                     class="blog-post-hero__image"
                                     alt="{{ post.title }}">
                            </div>
                        {% endif %}

                        <div class="blog-post-hero__content">
                            {% if post.category %}
                                <span class="blog-post-hero__category">
                                    {{ post.category.name }}
                                </span>
                            {% endif %}

                            <h1 class="blog-post-hero__title">
                                {{ post.title }}
                            </h1>

                            <p class="blog-post-hero__description">
                                {{ post.description }}
                            </p>

                            <div class="blog-post-hero__meta">
                                <span>Publié {{ post.publishedAt|ago }}</span>
                                <span>Par <strong>Oumi</strong></span>
                            </div>

                            {% if post.tags is not empty %}
                                <div class="blog-post-hero__tags">
                                    {% for tag in post.tags %}
                                        <span class="blog-post-hero__tag">
                                            #{{ tag.name }}
                                        </span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                    </article>

                    <div class="blog-post-layout mt-5">

                        <div class="blog-post-content-card">
                            <div class="blog-post-content">
                                {{ post.content|raw }}
                            </div>

                            <div class="blog-post-reactions">
                                <a id="like-link"
                                   class="blog-post-like-btn"
                                   href="{{ path('app_visitor_blog_post_like', {'id': post.id, 'slug': post.slug}) }}">
                                    {% if app.user and post.isLikedBy(app.user) %}
                                        <i class="fa-solid fa-thumbs-up"></i>
                                    {% else %}
                                        <i class="fa-regular fa-thumbs-up"></i>
                                    {% endif %}
                                    <span id="total-likes-container">{{ post.likes|length }}</span>
                                    <span>J'aime</span>
                                </a>
                            </div>
                        </div>

                        <div class="blog-post-comments-card mt-4" id="comments-container">
                            <div class="blog-post-comments-card__head">
                                <h2 class="blog-post-comments-card__title">
                                    Commentaires
                                </h2>
                                <p class="blog-post-comments-card__text mb-0">
                                    Partagez votre retour sur cet article.
                                </p>
                            </div>

                            {% if app.user %}
                                <div class="blog-post-comment-form">
                                    {{ form_start(form, {'action': path('app_visitor_blog_post_show', {'id': post.id, 'slug': post.slug}) ~ '#comments-container'}) }}

                                    <div class="mb-3">
                                        <label for="comment_form_content" class="form-label">
                                            Laisser un commentaire
                                        </label>
                                        <div class="text-danger small mb-2">
                                            {{ form_errors(form.content) }}
                                        </div>
                                        {{ form_widget(form.content, {
                                            'attr': {
                                                'class': 'form-control blog-post-textarea',
                                                'rows': 5,
                                                'placeholder': 'Écrivez votre commentaire ici...'
                                            }
                                        }) }}
                                    </div>

                                    <div>
                                        <input type="submit" class="btn btn-cta rounded-pill px-4" value="Publier mon commentaire">
                                    </div>

                                    {{ form_end(form) }}
                                </div>
                            {% else %}
                                <div class="blog-post-login-box">
                                    <p class="mb-3">
                                        Connectez-vous ou inscrivez-vous pour donner votre avis.
                                    </p>

                                    <div class="d-flex flex-wrap gap-2">
                                        <a href="{{ path('app_login') }}" class="btn btn-outline-success rounded-pill px-4">
                                            Me connecter
                                        </a>
                                        <a href="{{ path('app_register') }}" class="btn btn-success rounded-pill px-4">
                                            M'inscrire
                                        </a>
                                    </div>
                                </div>
                            {% endif %}

                            {% set activeComments = post.comments|filter(comment => comment.isActivated) %}
                            {% if activeComments|length > 0 %}
                                <div class="blog-post-comments-list mt-4">
                                    {% for comment in post.comments|reverse %}
                                        {% if comment.isActivated %}
                                            <div class="blog-post-comment">
                                                <div class="blog-post-comment__head">
                                                    <div>
                                                        <p class="blog-post-comment__author mb-0">
                                                            {% if comment.user %}
                                                                {{ comment.user.firstName }} {{ comment.user.lastName }}
                                                            {% else %}
                                                                Utilisateur inconnu
                                                            {% endif %}
                                                        </p>
                                                        <p class="blog-post-comment__date mb-0">
                                                            {{ comment.activatedAt ? 'Publié ' ~ comment.activatedAt|ago : '' }}
                                                        </p>
                                                    </div>
                                                </div>

                                                <div class="blog-post-comment__content">
                                                    {{ comment.content|nl2br }}
                                                </div>
                                            </div>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="blog-post-empty-comments mt-4">
                                    Aucun commentaire pour le moment.
                                </div>
                            {% endif %}
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </section>
{% endblock %}

{% block j_Query %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
            integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"></script>
{% endblock %}

{% block specific_js %}
    <script>
        $(document).ready(function () {
            $('#like-link').on('click', function (event) {
                event.preventDefault();

                const icon = $(this).find('i');

                $.ajax({
                    url: this.href,
                    type: 'GET',
                    success: function (response) {
                        $("#total-likes-container").html(response.totalLikesUpdated);

                        if (icon.hasClass('fa-regular')) {
                            icon.removeClass('fa-regular').addClass('fa-solid');
                        } else {
                            icon.removeClass('fa-solid').addClass('fa-regular');
                        }
                    },
                    error: function (response) {
                        if (response.status === 403) {
                            alert(response.responseJSON.message);
                        } else {
                            alert("Une erreur est survenue, veuillez réessayer");
                        }
                    }
                });
            });
        });
    </script>
{% endblock %}