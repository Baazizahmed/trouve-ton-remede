{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Articles & conseils{% endblock %}

{% block description %}
Lisez les articles d’Oumi sur les remèdes naturels, le bien-être et les plantes médicinales.
{% endblock %}

{% block knp_paginator_rel_links %}
    {{ knp_pagination_rel_links(posts) }}
{% endblock %}

{% block main %}
    {% include 'components/visitor/header-visitor.html.twig' with {
        h1: 'Articles & conseils',
        subtitle: 'Explorez les remèdes, les conseils de bien-être et les plantes médicinales d’Oumi.'
    } %}

    <section class="py-5 section-blog-index">
        <div class="container">

            {# Filtres catégories / tags #}
            <div class="row justify-content-center mb-4">
                <div class="col-lg-10">
                    <div class="d-flex flex-column flex-md-row gap-3 justify-content-between">
                        <div class="dropdown">
                            <button class="btn btn-outline-success dropdown-toggle" type="button"
                                    id="dropdownCategories" data-bs-toggle="dropdown" aria-expanded="false">
                                Catégories
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="dropdownCategories">
                                {% if categories is not empty %}
                                    {% for category in categories %}
                                        {% set categoryPostsLength = category.posts|length %}
                                        <li>
                                            <a class="dropdown-item"
                                               href="{{ path('app_visitor_blog_filter_by_category', {
                                                   id: category.id,
                                                   slug: category.slug
                                               }) }}">
                                                {{ category.name }}
                                                ({{ categoryPostsLength }} article{{ categoryPostsLength > 1 ? 's' : '' }})
                                            </a>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li><span class="dropdown-item text-muted">Aucune catégorie disponible</span></li>
                                {% endif %}
                            </ul>
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-outline-success dropdown-toggle" type="button"
                                    id="dropdownTags" data-bs-toggle="dropdown" aria-expanded="false">
                                Tags
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="dropdownTags">
                                {% if tags is not empty %}
                                    {% for tag in tags %}
                                        {% set tagPostsLength = tag.posts|length %}
                                        <li>
                                            <a class="dropdown-item"
                                               href="{{ path('app_visitor_blog_filter_by_tag', {
                                                   id: tag.id,
                                                   slug: tag.slug
                                               }) }}">
                                                {{ tag.name }}
                                                ({{ tagPostsLength }} article{{ tagPostsLength > 1 ? 's' : '' }})
                                            </a>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li><span class="dropdown-item text-muted">Aucun tag disponible</span></li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            {# Liste des articles #}
            <div class="row">
                <div class="col-lg-10 mx-auto">
                    {% for post in posts %}
                        <article class="card blog-card mb-4 border-0 shadow-sm">
                            <div class="row g-0">
                                <div class="col-md-4">
                                    {% if post.image %}
                                        <img
                                            src="{{ vich_uploader_asset(post, 'imageFile') | imagine_filter('visitor_post_thumb') }}"
                                            class="blog-card__image"
                                            alt="{{ post.title }}"
                                        >
                                    {% else %}
                                        <img
                                            src="/images/static/blog/default_post_image.png"
                                            class="blog-card__image"
                                            alt="{{ post.title }}"
                                        >
                                    {% endif %}
                                </div>
                                <div class="col-md-8">
                                    <div class="card-body blog-card__body">
                                        <h2 class="blog-card__title">
                                            {{ post.title|u.truncate(80, '…') }}
                                        </h2>

                                        <p class="blog-card__excerpt">
                                            {{ post.description|u.truncate(140, '…') }}
                                        </p>

                                        <p class="blog-card__meta mb-2">
                                            <span class="me-2">
                                                🌿 {{ post.category.name }}
                                            </span>
                                            <span class="text-muted">
                                                Publié {{ post.publishedAt|ago }}
                                            </span>
                                        </p>

                                        {% if post.tags is not empty %}
                                            <p class="mb-3">
                                                {% for tag in post.tags %}
                                                    <span class="badge rounded-pill bg-success-subtle text-success me-1">
                                                        {{ tag.name }}
                                                    </span>
                                                {% endfor %}
                                            </p>
                                        {% endif %}

                                        <a href="{{ path('app_visitor_blog_post_show', {
                                            id: post.id,
                                            slug: post.slug
                                        }) }}"
                                           class="btn btn-cta btn-sm">
                                            Lire l'article
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </article>
                    {% else %}
                        <p class="text-center text-muted my-5">
                            Aucun article disponible pour le moment.
                        </p>
                    {% endfor %}

                    <div class="d-flex justify-content-end align-items-center mt-4">
                        {{ knp_pagination_render(posts) }}
                    </div>
                </div>
            </div>

        </div>
    </section>
{% endblock %}
