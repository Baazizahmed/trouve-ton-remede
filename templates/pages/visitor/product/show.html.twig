{% extends 'themes/base_visitor.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}
{% block description %}{{ product.description|u.truncate(150, '...') }}{% endblock %}

{% block main %}
    <section class="py-4">
        <div class="container">

            {# Fil d'Ariane #}
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb small">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_visitor_welcome') }}">Accueil</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_visitor_product_index') }}">Plantes médicinales</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        {{ product.name }}
                    </li>
                </ol>
            </nav>

            <div class="row g-4">

                {# Colonne image #}
                <div class="col-md-5">
                    <div class="product-image-wrapper">
                        {% if product.imageName %}
                            <img
                                src="{{ asset('images/dynamic/products/' ~ product.imageName) }}"
                                class="product-image-main"
                                alt="{{ product.name }}"
                            >
                        {% else %}
                            <div class="product-image-placeholder">
                                🌿
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Colonne contenu #}
                <div class="col-md-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body d-flex flex-column">

                            <h1 class="h3 fw-bold mb-2">{{ product.name }}</h1>

                            <p class="text-muted mb-1">
                                Plante médicinale naturelle
                            </p>

                            {# Prix #}
                            <div class="product-price-block mb-3">
                                <span class="product-price-main">
                                    {{ product.price|number_format(2, ',', ' ') }} €
                                </span>
                                <span class="product-price-note">
                                    TTC – TVA 20 % incluse
                                </span>
                            </div>

                            {# Description courte / longue #}
                            {% if product.shortDescription is defined and product.shortDescription %}
                                <p class="product-short-desc mb-3">
                                    {{ product.shortDescription }}
                                </p>
                            {% else %}
                                <p class="product-short-desc mb-3">
                                    {{ product.description }}
                                </p>
                            {% endif %}

                            {# Bienfaits #}
                            {% if product.benefits is defined and product.benefits %}
                                <h2 class="h5 mt-3">Bienfaits</h2>
                                <p>{{ product.benefits|nl2br }}</p>
                            {% endif %}

                            {# Utilisation #}
                            {% if product.usage is defined and product.usage %}
                                <h2 class="h5 mt-3">Utilisation</h2>
                                <p>{{ product.usage|nl2br }}</p>
                            {% endif %}

                            {# CTA Ajouter au panier #}
                            <div class="mt-auto pt-3">
                                <form action="{{ path('app_cart_add', { id: product.id }) }}"
                                      method="post"
                                      class="d-flex flex-wrap align-items-center gap-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <label for="quantity" class="form-label mb-0 small text-muted">
                                            Quantité
                                        </label>
                                        <input type="number"
                                               name="quantity"
                                               id="quantity"
                                               class="form-control form-control-sm w-auto"
                                               value="1"
                                               min="1">
                                    </div>

                                    <button type="submit" class="btn btn-cta btn-lg">
                                        <i class="fa-solid fa-cart-plus me-1"></i>
                                        Ajouter au panier
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
{% endblock %}
