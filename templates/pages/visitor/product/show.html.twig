{% extends 'themes/base_visitor.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}
{% block description %}{{ product.description|u.truncate(150, '...') }}{% endblock %}

{% block main %}
<section class="py-5">
    <div class="container">

        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_visitor_welcome') }}">Accueil</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_visitor_product_index') }}">Plantes médicinales</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    {{ product.name }}
                </li>
            </ol>
        </nav>

        <div class="row g-4 align-items-start">

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-3 p-md-4">
                        {% if product.imageName %}
                            <img
                                src="{{ asset('images/dynamic/products/' ~ product.imageName) }}"
                                class="img-fluid rounded-4 w-100"
                                alt="{{ product.name }}"
                                style="object-fit: cover;"
                            >
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center rounded-4 bg-light"
                                 style="min-height: 320px; font-size: 4rem;">
                                🌿
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4 p-lg-5 d-flex flex-column">

                        <span class="badge rounded-pill text-bg-success align-self-start mb-3">
                            Sélectionnée avec soin
                        </span>

                        <h1 class="h2 fw-bold mb-2">{{ product.name }}</h1>

                        <p class="text-muted mb-3">
                            Plante médicinale naturelle pour accompagner votre bien-être au quotidien.
                        </p>

                        <div class="mb-3">
                            <span class="fs-3 fw-bold text-success">
                                {{ product.price|number_format(2, ',', ' ') }} €
                            </span>
                            <span class="d-block small text-muted mt-1">
                                TTC – TVA 20 % incluse
                            </span>
                        </div>

                        {% if product.shortDescription is defined and product.shortDescription %}
                            <p class="lead mb-4">
                                {{ product.shortDescription }}
                            </p>
                        {% else %}
                            <p class="lead mb-4">
                                {{ product.description }}
                            </p>
                        {% endif %}

                        <div class="p-3 p-md-4 rounded-4 bg-light mb-4">
                            <h2 class="h5 fw-bold mb-3">Pourquoi choisir cette plante ?</h2>

                            {% if product.benefits is defined and product.benefits %}
                                <div class="small">
                                    {{ product.benefits|nl2br }}
                                </div>
                            {% else %}
                                <ul class="mb-0 ps-3">
                                    <li>Une solution naturelle pour votre routine bien-être.</li>
                                    <li>Une plante appréciée pour ses usages traditionnels.</li>
                                    <li>Simple à intégrer dans votre quotidien.</li>
                                </ul>
                            {% endif %}
                        </div>

                        {% if product.usage is defined and product.usage %}
                            <div class="mb-4">
                                <h2 class="h5 fw-bold mb-3">Conseils d’utilisation</h2>
                                <div class="text-muted">
                                    {{ product.usage|nl2br }}
                                </div>
                            </div>
                        {% endif %}

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <div class="h-100 p-3 rounded-4 border bg-white">
                                    <div class="mb-2">🌿</div>
                                    <p class="small mb-0">
                                        Produit naturel sélectionné avec attention
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="h-100 p-3 rounded-4 border bg-white">
                                    <div class="mb-2">🚚</div>
                                    <p class="small mb-0">
                                        Expédition soignée et livraison suivie
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="h-100 p-3 rounded-4 border bg-white">
                                    <div class="mb-2">💬</div>
                                    <p class="small mb-0">
                                        Conseils bien-être disponibles sur le blog
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="border-top pt-4 mt-auto">
                            <form action="{{ path('app_cart_add', { id: product.id }) }}"
                                  method="post"
                                  class="d-flex flex-wrap align-items-end gap-3">

                                <div>
                                    <label for="quantity" class="form-label small text-muted">
                                        Quantité
                                    </label>
                                    <input
                                        type="number"
                                        name="quantity"
                                        id="quantity"
                                        class="form-control"
                                        value="1"
                                        min="1"
                                        style="max-width: 100px;"
                                    >
                                </div>

                                <button type="submit" class="btn btn-success btn-lg rounded-pill px-4 shadow-sm">
                                    <i class="fa-solid fa-cart-plus me-2"></i>
                                    Ajouter au panier
                                </button>
                            </form>

                            <p class="small text-muted mt-3 mb-0">
                                Paiement sécurisé • Livraison soignée • Service client disponible
                            </p>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <div class="row mt-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">À savoir avant consommation</h2>
                        <p class="text-muted mb-0">
                            Les informations présentes sur cette page sont données à titre informatif et ne remplacent pas l’avis d’un professionnel de santé. En cas de doute, de grossesse, d’allaitement ou de traitement en cours, demandez conseil à un professionnel.
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
{% endblock %}