{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Nos Plantes Médicinales{% endblock %}

{% block main %}
<section class="py-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <div>
                <h1 class="h3 fw-bold mb-1">Nos plantes médicinales</h1>
                <p class="text-muted mb-0">
                    Découvrez la sélection de plantes naturelles d’Oumi pour votre bien-être.
                </p>
            </div>
        </div>

        {% if products is not empty %}
            <div class="row g-4">
                {% for product in products %}
                    <div class="col-md-4 col-sm-6">
                        <article class="card-produit h-100">

                            {% if product.imageName %}
                                <div class="card-produit__image-wrapper">
                                    <img
                                        src="{{ asset('images/dynamic/products/' ~ product.imageName) }}"
                                        class="card-produit__image"
                                        alt="{{ product.name }}"
                                    >
                                </div>
                            {% endif %}

                            <div class="card-produit__body">
                                <h2 class="card-produit__title">
                                    {{ product.name }}
                                </h2>

                                <p class="card-produit__excerpt">
                                    {{ product.description|u.truncate(90, '...') }}
                                </p>

                                <div class="card-produit__footer">
                                    <span class="card-produit__price">
                                        {{ product.price|number_format(2, ',', ' ') }} €
                                    </span>

                                    <a href="{{ path('app_visitor_product_show', {'slug': product.slug}) }}"
                                       class="btn btn-sm btn-primary">
                                        Voir la plante
                                    </a>
                                </div>
                            </div>

                        </article>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-muted">
                Aucun produit disponible pour le moment.
            </p>
        {% endif %}

    </div>
</section>
{% endblock %}
